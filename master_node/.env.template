# --- Database & Redis ---
DATABASE_URL=postgres://user:password@localhost:5432/byteaway
REDIS_URL=redis://localhost:6379

# --- API Configuration ---
API_PORT=3000
SOCKS5_PORT=1080
VPN_PORT=5443
PRICE_PER_GB_USD=5.0

# --- VPN / VLESS Reality Configuration ---
# Public IP or Domain of the master node
VPN_PUBLIC_HOST=byteaway.xyz
# Optional dedicated RU egress for node-local proxy configs (/api/v1/vpn/config?use_ru_egress=1)
NODE_RU_EGRESS_HOST=
NODE_RU_EGRESS_PORT=5443

# Reality Private Key (Generate using 'sing-box generate reality-keypair')
REALITY_PRIVATE_KEY=YOUR_GENERATED_PRIVATE_KEY
# Reality Public Key (Generate using 'sing-box generate reality-keypair')
REALITY_PUBLIC_KEY=YOUR_GENERATED_PUBLIC_KEY

# Short ID (any 8-16 hex characters)
REALITY_SHORT_ID=0123456789abcdef

# Destination for Reality masking (standard HTTPS site)
REALITY_DEST=google.com:443

# UUID that must match sing-box inbound `users[].uuid` in `master_node/sing-box/config.json`
VPN_CLIENT_UUID=49557a2f-e8b8-4c63-9524-76839a8579ca

# --- Hysteria2 (QUIC) transport for node relay ---
HY2_PORT=9443
HY2_PASSWORD=G8k3vQ9pLm2sT7xY4nR6cD1hW5jZ0aFp

# --- Native QUIC node ingress (no WebSocket required for future clients) ---
NODE_QUIC_ENABLED=true
NODE_QUIC_PORT=3443
NODE_QUIC_CERT_PATH=./certs/node_quic.crt
NODE_QUIC_KEY_PATH=./certs/node_quic.key

# --- Cloudflare Turnstile (Captcha) ---
# Create widget and get keys: https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SECRET_KEY=YOUR_TURNSTILE_SECRET_KEY
TURNSTILE_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify

# --- Secure app OTA update flow ---
# Path to static android update manifest file generated during web deploy
APP_UPDATE_MANIFEST_PATH=/var/www/byteaway-web/dist/downloads/android.json
# Public base URL used to build absolute secure OTA links
PUBLIC_BASE_URL=https://byteaway.xyz
